{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "outDir": "./src",
    "rootDir": "./src",
    "typeRoots": ["./node_modules/@figma", "./node_modules/@types"]
  },
  "include": ["src/code.ts"],
  "exclude": ["node_modules", "src/ui.html"]
}
